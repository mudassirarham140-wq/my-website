<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Skyline Shop</title>
  <style>
    :root {
      color-scheme: light;
      --bg: #f3f6ff;
      --surface: #ffffff;
      --surface-strong: #eef2ff;
      --surface-soft: #f8fbff;
      --text: #0f172a;
      --muted: #475569;
      --primary: #2563eb;
      --accent: #f59e0b;
      --danger: #dc2626;
      --shadow: 0 24px 70px rgba(15, 23, 42, 0.12);
      --radius: 22px;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      min-height: 100vh;
      background: radial-gradient(circle at top left, rgba(59, 130, 246, 0.16), transparent 24%),
                  radial-gradient(circle at bottom right, rgba(34, 197, 94, 0.12), transparent 24%),
                  linear-gradient(180deg, #eef2ff 0%, #ffffff 55%, #f8fafc 100%);
      color: var(--text);
      line-height: 1.5;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    img {
      max-width: 100%;
      display: block;
    }

    button,
    input,
    select,
    textarea {
      font: inherit;
    }

    .page-header {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 1000;
      background: rgba(15, 23, 42, 0.95);
      color: #fff;
      padding: 6px 12px;
      backdrop-filter: blur(14px);
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }

    .topbar {
      display: grid;
      grid-template-columns: 1fr auto;
      align-items: center;
      gap: 8px;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .brand-hero {
      font-size: 1.1rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      color: #fde68a;
    }

    .brand-subtitle {
      color: rgba(255, 255, 255, 0.78);
      font-size: 0.95rem;
    }

    .nav-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      justify-content: flex-end;
      align-items: center;
    }

    .nav-actions button,
    .nav-actions select {
      border-radius: 999px;
      border: 1px solid rgba(255, 255, 255, 0.18);
      background: rgba(255, 255, 255, 0.95);
      color: var(--text);
      font-weight: 700;
      padding: 8px 10px;
      cursor: pointer;
      min-width: 90px;
    }

    .search-control {
      display: grid;
      gap: 6px;
      margin-top: 8px;
    }

    .search-panel {
      display: flex;
      gap: 0;
      border-radius: 999px;
      overflow: hidden;
      background: #fff;
      border: 1px solid rgba(15, 23, 42, 0.1);
    }

    .search-panel input {
      flex: 1;
      border: none;
      padding: 8px 10px;
      font-size: 0.92rem;
      outline: none;
    }

    .search-panel button {
      border: none;
      background: var(--primary);
      color: #fff;
      padding: 0 12px;
      font-weight: 700;
    }

    .hero {
      margin: 28px auto;
      max-width: 1180px;
      display: grid;
      grid-template-columns: 1.2fr 0.8fr;
      gap: 24px;
    }

    .hero-card {
      background: linear-gradient(135deg, #2563eb, #8b5cf6);
      border-radius: var(--radius);
      padding: 36px;
      color: #fff;
      box-shadow: var(--shadow);
    }

    .hero-card h1 {
      font-size: clamp(2.6rem, 4vw, 3.8rem);
      margin-bottom: 18px;
      line-height: 1.02;
    }

    .hero-card p {
      color: rgba(255, 255, 255, 0.88);
      font-size: 1.05rem;
      max-width: 560px;
      margin-bottom: 24px;
    }

    .hero-card .hero-buttons {
      display: flex;
      flex-wrap: wrap;
      gap: 14px;
    }

    .hero-card button {
      border: none;
      border-radius: 16px;
      padding: 16px 24px;
      font-weight: 700;
      cursor: pointer;
      color: #111;
      background: #fcd34d;
      transition: transform 180ms ease;
    }

    .hero-card button:hover {
      transform: translateY(-2px);
    }

    .hero-quick {
      display: grid;
      gap: 18px;
    }

    .quick-card {
      background: #fff;
      border-radius: var(--radius);
      padding: 24px;
      box-shadow: var(--shadow);
    }

    .quick-card h2 {
      font-size: 1.3rem;
      margin-bottom: 14px;
    }

    .quick-card p {
      color: var(--muted);
      line-height: 1.75;
    }

    .page-body {
      max-width: 1180px;
      margin: 0 auto 36px;
      padding: 0 24px;
      display: grid;
      grid-template-columns: 280px minmax(0, 1fr);
      gap: 22px;
    }

    .sidebar {
      display: grid;
      gap: 20px;
    }

    .panel {
      background: var(--surface);
      border-radius: var(--radius);
      padding: 24px;
      box-shadow: var(--shadow);
      border: 1px solid rgba(15, 23, 42, 0.04);
    }

    .panel h3 {
      margin-bottom: 16px;
      font-size: 1.1rem;
    }

    .pill-list {
      display: grid;
      gap: 10px;
    }

    .pill-list button {
      border: 1px solid rgba(15, 23, 42, 0.08);
      border-radius: 999px;
      background: var(--surface-soft);
      color: var(--text);
      padding: 14px 16px;
      text-align: left;
      transition: background 180ms ease, transform 180ms ease;
      cursor: pointer;
    }

    .pill-list button.active,
    .pill-list button:hover {
      background: var(--primary);
      color: #fff;
      transform: translateY(-1px);
    }

    .panel .stat-row {
      display: grid;
      gap: 14px;
      margin-top: 16px;
    }

    .stat-card {
      background: var(--surface-soft);
      border-radius: 20px;
      padding: 18px;
      display: grid;
      gap: 6px;
    }

    .stat-card strong {
      font-size: 1.2rem;
    }

    .hero-buttons .badge,
    .section-label {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      background: rgba(255, 255, 255, 0.16);
      color: #fff;
      padding: 10px 14px;
      border-radius: 999px;
      font-weight: 700;
      font-size: 0.95rem;
    }

    .market-header {
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      gap: 20px;
      align-items: center;
      margin-bottom: 18px;
    }

    .market-header h2 {
      font-size: 1.8rem;
    }

    .market-header p {
      color: var(--muted);
      margin-top: 6px;
      max-width: 480px;
    }

    .market-top {
      display: grid;
      gap: 18px;
      margin-bottom: 18px;
      grid-template-columns: 1fr auto;
      align-items: center;
    }

    .market-top label {
      display: flex;
      align-items: center;
      gap: 12px;
      color: var(--muted);
      font-weight: 700;
    }

    .market-top select {
      padding: 12px 14px;
      border-radius: 16px;
      border: 1px solid rgba(15, 23, 42, 0.1);
      background: var(--surface);
      color: var(--text);
    }

    .product-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 20px;
    }

    .product-card {
      position: relative;
      background: var(--surface);
      border-radius: 26px;
      overflow: hidden;
      box-shadow: var(--shadow);
      display: grid;
      grid-template-rows: auto 1fr auto;
      transition: transform 180ms ease, box-shadow 180ms ease;
    }

    .product-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 32px 80px rgba(15, 23, 42, 0.18);
    }

    .product-card .badge-top {
      position: absolute;
      top: 18px;
      left: 18px;
      background: var(--accent);
      color: #111;
      padding: 8px 14px;
      border-radius: 999px;
      font-size: 0.8rem;
      font-weight: 700;
      z-index: 2;
    }

    .product-image {
      position: relative;
      overflow: hidden;
    }

    .product-image img {
      width: 100%;
      height: 200px;
      object-fit: cover;
      transition: transform 220ms ease;
    }

    .product-card:hover .product-image img {
      transform: scale(1.05);
    }

    .product-body {
      padding: 22px;
      display: grid;
      gap: 14px;
    }

    .product-body h3 {
      margin: 0;
      font-size: 1.1rem;
    }

    .product-body p {
      color: var(--muted);
      font-size: 0.95rem;
      line-height: 1.7;
      min-height: 3.2em;
    }

    .product-meta {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      align-items: center;
    }

    .product-price {
      font-size: 1.2rem;
      font-weight: 800;
      color: var(--text);
    }

    .product-actions {
      display: grid;
      gap: 12px;
      padding: 0 22px 22px;
    }

    .product-actions button {
      width: 100%;
      border: none;
      border-radius: 16px;
      padding: 14px 18px;
      font-weight: 700;
      cursor: pointer;
    }

    .btn-primary {
      background: var(--primary);
      color: #fff;
    }

    .btn-outline {
      background: var(--surface-soft);
      color: var(--text);
      border: 1px solid rgba(15, 23, 42, 0.08);
    }

    .btn-small {
      font-size: 0.95rem;
      padding: 12px 14px;
    }

    .count-badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 26px;
      height: 26px;
      background: var(--accent);
      color: #111;
      border-radius: 999px;
      font-size: 0.85rem;
      font-weight: 700;
    }

    .no-results {
      padding: 40px;
      text-align: center;
      color: var(--muted);
      font-size: 1rem;
      grid-column: 1 / -1;
      border-radius: var(--radius);
      background: var(--surface);
      box-shadow: var(--shadow);
    }

    .section-row {
      display: grid;
      gap: 20px;
      margin-top: 30px;
    }

    .section-row .card-grid {
      display: grid;
      gap: 18px;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    }

    .info-card {
      background: var(--surface);
      border-radius: 24px;
      padding: 22px;
      box-shadow: var(--shadow);
      border: 1px solid rgba(15, 23, 42, 0.04);
    }

    .info-card h3 {
      margin-bottom: 10px;
    }

    .info-card p {
      color: var(--muted);
      line-height: 1.75;
    }

    .modal,
    .drawer {
      position: fixed;
      inset: 0;
      z-index: 1200;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
      background: rgba(15, 23, 42, 0.6);
    }

    .modal.hidden,
    .drawer.hidden {
      display: none;
    }

    .modal-panel,
    .drawer-panel {
      width: min(760px, 100%);
      max-height: min(96vh, 760px);
      overflow: auto;
      background: var(--surface);
      border-radius: var(--radius);
      padding: 28px;
      box-shadow: var(--shadow);
      position: relative;
    }

    .drawer-panel {
      width: min(560px, 100%);
      max-height: 100vh;
      margin: auto 0;
    }

    .modal-close {
      position: absolute;
      right: 20px;
      top: 20px;
      border: none;
      background: transparent;
      font-size: 1.6rem;
      color: var(--muted);
      cursor: pointer;
    }

    .tabs {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      margin-bottom: 22px;
    }

    .tab {
      border: 1px solid rgba(15, 23, 42, 0.12);
      border-radius: 999px;
      background: var(--surface-soft);
      padding: 10px 16px;
      cursor: pointer;
      font-weight: 700;
    }

    .tab.active {
      background: var(--primary);
      color: #fff;
      border-color: rgba(37, 99, 235, 0.24);
    }

    .tab-panel {
      display: none;
    }

    .tab-panel.active {
      display: block;
    }

    .form-group {
      display: grid;
      gap: 10px;
      margin-bottom: 16px;
    }

    .form-group label {
      font-weight: 700;
      color: var(--text);
    }

    .form-group input,
    .form-group select,
    .form-group textarea {
      width: 100%;
      border-radius: 16px;
      border: 1px solid rgba(15, 23, 42, 0.12);
      padding: 14px 16px;
      background: var(--surface);
      color: var(--text);
    }

    .form-group textarea {
      min-height: 110px;
      resize: vertical;
    }

    .panel-footer {
      display: grid;
      gap: 14px;
      margin-top: 18px;
    }

    .product-gallery {
      display: grid;
      gap: 14px;
    }

    .gallery-main {
      width: 100%;
      height: 320px;
      border-radius: 24px;
      overflow: hidden;
      position: relative;
      background: #f1f5f9;
    }

    .gallery-main img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .gallery-thumbs {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 10px;
    }

    .gallery-thumb {
      border-radius: 18px;
      overflow: hidden;
      cursor: pointer;
      border: 2px solid transparent;
    }

    .gallery-thumb img {
      width: 100%;
      height: 70px;
      object-fit: cover;
    }

    .gallery-thumb.active {
      border-color: var(--primary);
    }

    .related-list {
      display: grid;
      gap: 14px;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    }

    .related-card {
      display: grid;
      gap: 10px;
      padding: 16px;
      border-radius: 20px;
      background: var(--surface-soft);
      border: 1px solid rgba(15, 23, 42, 0.08);
    }

    .related-card button {
      border: none;
      border-radius: 14px;
      padding: 12px;
      background: var(--primary);
      color: #fff;
      cursor: pointer;
      font-weight: 700;
    }

    .badge-pill {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      padding: 10px 14px;
      border-radius: 999px;
      background: var(--surface-soft);
      color: var(--text);
      font-weight: 700;
    }

    .split-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }

    .account-card {
      display: grid;
      gap: 12px;
      padding: 20px;
      background: var(--surface-soft);
      border: 1px solid rgba(15, 23, 42, 0.08);
      border-radius: 24px;
    }

    .account-card strong {
      font-size: 1.05rem;
    }

    .table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 16px;
    }

    .table th,
    .table td {
      padding: 14px 12px;
      text-align: left;
      border-bottom: 1px solid rgba(15, 23, 42, 0.08);
    }

    .table th {
      color: var(--text);
      font-weight: 700;
    }

    .link-button {
      border: none;
      background: transparent;
      color: var(--primary);
      cursor: pointer;
      font-weight: 700;
      padding: 0;
    }

    @media (max-width: 1100px) {
      .hero,
      .page-body {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 720px) {
      .page-header,
      .hero-card,
      .panel,
      .product-card,
      .modal-panel,
      .drawer-panel {
        border-radius: 20px;
      }

      .topbar {
        grid-template-columns: 1fr;
      }

      .nav-actions {
        justify-content: stretch;
      }

      .search-panel {
        flex-direction: column;
      }

      .search-panel button,
      .nav-actions button,
      .nav-actions select {
        width: 100%;
      }

      .market-top {
        grid-template-columns: 1fr;
      }

      .gallery-thumbs {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }
    }
  </style>
</head>
<body>
  <header class="page-header">
    <div class="topbar">
      <div class="brand">
        <div class="brand-hero">Skyline Shop</div>
        <div class="brand-subtitle">All-in-one marketplace demo for customers, sellers, and admins.</div>
      </div>
      <div class="nav-actions">
        <select id="currencySelector" aria-label="Currency selector">
          <option value="USD">USD</option>
          <option value="EUR">EUR</option>
          <option value="GBP">GBP</option>
          <option value="INR">INR</option>
          <option value="PKR">PKR</option>
          <option value="JPY">JPY</option>
        </select>
        <button id="wishListButton">Wishlist <span class="count-badge" id="wishCount">0</span></button>
        <button id="compareButton">Compare <span class="count-badge" id="compareCount">0</span></button>
        <button id="cartButton">Cart <span class="count-badge" id="cartCount">0</span></button>
        <button id="profileButton">Profile</button>
      </div>
    </div>
    <div class="search-control">
      <form id="searchForm" class="search-panel">
        <input id="searchInput" type="search" placeholder="Search products, brands, categories" aria-label="Search products" />
        <button type="submit">Search</button>
      </form>
      <div class="market-header">
        <div>
          <h2>Smart storefront for family sellers and shoppers.</h2>
          <p>Search, compare, wishlist, checkout, and explore deals with a modern single-page marketplace experience.</p>
        </div>
        <div class="hero-buttons">
          <span class="section-label">Live customer features</span>
        </div>
      </div>
    </div>
  </header>

  <section class="hero">
    <div class="hero-card">
      <h1>Shopping made simple. Feature-rich. Fully interactive.</h1>
      <p>Build an Amazon-style storefront with product filtering, detailed views, wishlist, compare, checkout flow, user accounts, order history, and seller analytics.</p>
      <div class="hero-buttons">
        <button type="button" id="viewProductsBtn">Browse Products</button>
        <button type="button" id="viewDealsBtn">Flash Deals</button>
      </div>
    </div>
    <div class="hero-quick">
      <div class="quick-card">
        <h2>Best Sellers</h2>
        <p>Fast-moving favorites from multiple categories, updated in real time as shoppers add items.</p>
      </div>
      <div class="quick-card">
        <h2>New Arrivals</h2>
        <p>Fresh products added by sellers with live price conversion for your chosen currency.</p>
      </div>
    </div>
  </section>

  <main class="page-body">
    <aside class="sidebar">
      <div class="panel">
        <h3>Product Categories</h3>
        <div class="pill-list" id="categoryList"></div>
      </div>

      <div class="panel">
        <h3>Deals</h3>
        <div class="stat-row">
          <div class="stat-card">
            <strong>Flash Deals</strong>
            <p>Hot discounts live now across electronics and fashion.</p>
          </div>
          <div class="stat-card">
            <strong>Daily Coupons</strong>
            <p>Use STACK10 or SAVE15 for instant checkout savings.</p>
          </div>
        </div>
      </div>

      <div class="panel">
        <h3>Seller Dashboard</h3>
        <p>Track listings, orders, inventory, coupons, and earnings with a seller-ready workspace.</p>
        <div class="stat-row">
          <div class="stat-card">
            <strong>Products</strong>
            <span id="sellerProductsCount">0</span>
          </div>
          <div class="stat-card">
            <strong>Orders</strong>
            <span id="sellerOrdersCount">5</span>
          </div>
        </div>
      </div>
    </aside>

    <section>
      <div class="market-top">
        <div>
          <h2>Featured Products</h2>
          <p>Explore top sellers, new arrivals, daily deals, and curated product bundles in one place.</p>
        </div>
        <div>
          <label>
            Sort by
            <select id="sortSelect" aria-label="Sort products">
              <option value="popular">Most popular</option>
              <option value="new">New arrivals</option>
              <option value="low">Price low to high</option>
              <option value="high">Price high to low</option>
              <option value="rating">Rating</option>
            </select>
          </label>
        </div>
      </div>

      <div class="product-grid" id="productGrid"></div>
      <div class="no-results hidden" id="noResults">No products match your search or filters. Try another keyword.</div>

      <div class="section-row">
        <div class="info-card">
          <h3>Recently Viewed</h3>
          <div id="recentlyViewed" class="related-list"></div>
        </div>
        <div class="info-card">
          <h3>Frequently Bought Together</h3>
          <p>Customers who viewed these items also added a bundle to checkout.</p>
          <div class="related-list" id="bundleList"></div>
        </div>
      </div>

      <div class="section-row">
        <div class="info-card">
          <h3>Gift Cards</h3>
          <p>Offer gift cards for easy gifting and store credit. Apply them at checkout.</p>
          <div class="badge-pill">GiftCard-50</div>
        </div>
        <div class="info-card">
          <h3>Customer Support</h3>
          <p>Contact page, FAQ, chat support, and ticket center are available to keep shoppers happy.</p>
        </div>
      </div>
    </section>
  </main>

  <div class="modal hidden" id="productModal" aria-hidden="true">
    <div class="modal-panel" role="dialog" aria-modal="true" aria-labelledby="productModalTitle">
      <button class="modal-close" id="productModalClose" aria-label="Close">×</button>
      <div class="split-grid">
        <div class="product-gallery">
          <div class="gallery-main" id="galleryMain"><img src="" alt="Product image" /></div>
          <div class="gallery-thumbs" id="galleryThumbs"></div>
        </div>
        <div>
          <div class="badge-pill" id="productStatus"></div>
          <h2 id="productModalTitle"></h2>
          <p id="productDescription"></p>
          <div class="product-meta">
            <div class="product-price" id="productPrice"></div>
            <div class="count-badge" id="productStock"></div>
          </div>
          <div class="panel-footer">
            <button class="btn-primary" id="modalAddCart">Add to cart</button>
            <button class="btn-outline" id="modalWishlist">Save to wishlist</button>
            <button class="btn-outline" id="modalCompare">Compare</button>
          </div>
          <div class="info-card" style="margin-top:18px;">
            <h3>Product video</h3>
