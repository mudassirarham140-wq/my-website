  <script>
    const productData = [
      { id: 'p1', title: 'Smart Speaker Plus', category: 'Electronics', tags: ['Best seller', 'Bundle'], description: 'Room-filling sound, voice assistant, and smart home support.', price: 149, stock: 26, rating: 4.8, image: 'https://via.placeholder.com/500x400?text=Smart+Speaker', gallery: ['https://via.placeholder.com/800x600?text=Speaker+1','https://via.placeholder.com/800x600?text=Speaker+2','https://via.placeholder.com/800x600?text=Speaker+3'], video: 'https://www.youtube.com/embed/dQw4w9WgXcQ', type: 'Best seller', section: 'Flash deal' },
      { id: 'p2', title: 'Noise Cancelling Headphones', category: 'Electronics', tags: ['New arrival', 'Popular'], description: 'Comfortable fit and immersive audio for work, travel, and play.', price: 99, stock: 14, rating: 4.7, image: 'https://via.placeholder.com/500x400?text=Headphones', gallery: ['https://via.placeholder.com/800x600?text=Headphones+1','https://via.placeholder.com/800x600?text=Headphones+2'], video: '', type: 'New arrival', section: 'Daily deal' },
      { id: 'p3', title: 'Designer Backpack', category: 'Fashion', tags: ['Trending', 'Bundle'], description: 'Durable, spacious, and ready for everyday adventures.', price: 69, stock: 35, rating: 4.6, image: 'https://via.placeholder.com/500x400?text=Backpack', gallery: ['https://via.placeholder.com/800x600?text=Backpack+1','https://via.placeholder.com/800x600?text=Backpack+2'], video: '', type: 'New arrival', section: 'Best seller' },
      { id: 'p4', title: 'LED Desk Lamp', category: 'Home & Kitchen', tags: ['Coupon', 'Recommended'], description: 'Adjustable brightness, USB charging, and sleek style.', price: 35, stock: 18, rating: 4.5, image: 'https://via.placeholder.com/500x400?text=Desk+Lamp', gallery: ['https://via.placeholder.com/800x600?text=Lamp+1','https://via.placeholder.com/800x600?text=Lamp+2'], video: '', type: 'Daily deal', section: 'Deals' },
      { id: 'p5', title: 'Classic Sport Watch', category: 'Fashion', tags: ['Popular', 'New arrival'], description: 'Water-resistant, lightweight, and ready to move with you.', price: 42, stock: 22, rating: 4.4, image: 'https://via.placeholder.com/500x400?text=Sport+Watch', gallery: ['https://via.placeholder.com/800x600?text=Watch+1','https://via.placeholder.com/800x600?text=Watch+2'], video: '', type: 'Best seller', section: 'Flash deal' },
      { id: 'p6', title: 'Smart Coffee Maker', category: 'Home & Kitchen', tags: ['Gift card', 'Coupon'], description: 'Brew faster with app control and programmable settings.', price: 79, stock: 9, rating: 4.3, image: 'https://via.placeholder.com/500x400?text=Coffee+Maker', gallery: ['https://via.placeholder.com/800x600?text=Coffee+1','https://via.placeholder.com/800x600?text=Coffee+2'], video: '', type: 'Daily deal', section: 'Deals' },
      { id: 'p7', title: 'Velvet Throw Blanket', category: 'Home & Kitchen', tags: ['Recommended'], description: 'Soft, warm, and styled for modern living rooms.', price: 45, stock: 42, rating: 4.2, image: 'https://via.placeholder.com/500x400?text=Blanket', gallery: ['https://via.placeholder.com/800x600?text=Blanket+1'], video: '', type: 'New arrival', section: 'Best seller' },
      { id: 'p8', title: 'Arcade Game Controller', category: 'Electronics', tags: ['Best seller', 'Popular'], description: 'Precision controls built for competitive gaming.', price: 59, stock: 12, rating: 4.6, image: 'https://via.placeholder.com/500x400?text=Controller', gallery: ['https://via.placeholder.com/800x600?text=Controller+1','https://via.placeholder.com/800x600?text=Controller+2'], video: '', type: 'Flash deal', section: 'Flash deal' }
    ];

    const coupons = {
      STACK10: 0.10,
      SAVE15: 0.15,
      GIFT50: 50
    };

    const categories = ['All', 'Electronics', 'Fashion', 'Home & Kitchen', 'Beauty', 'Toys'];
    let currentCategory = 'All';
    let currentSort = 'popular';
    let currentCurrency = 'USD';
    let currentProduct = null;
    let currentUser = JSON.parse(localStorage.getItem('skylineUser')) || null;
    let cart = JSON.parse(localStorage.getItem('skylineCart') || '[]');
    let wishlist = JSON.parse(localStorage.getItem('skylineWishlist') || '[]');
    let compare = JSON.parse(localStorage.getItem('skylineCompare') || '[]');
    let recentlyViewed = JSON.parse(localStorage.getItem('skylineRecentlyViewed') || '[]');
    let appliedCoupon = localStorage.getItem('skylineCoupon') || '';

    const DOM = {
      currencySelector: document.getElementById('currencySelector'),
      searchForm: document.getElementById('searchForm'),
      searchInput: document.getElementById('searchInput'),
      categoryList: document.getElementById('categoryList'),
      sortSelect: document.getElementById('sortSelect'),
      productGrid: document.getElementById('productGrid'),
      noResults: document.getElementById('noResults'),
      wishCount: document.getElementById('wishCount'),
      compareCount: document.getElementById('compareCount'),
      cartCount: document.getElementById('cartCount'),
      sellerProductsCount: document.getElementById('sellerProductsCount'),
      productModal: document.getElementById('productModal'),
      productModalClose: document.getElementById('productModalClose'),
      galleryMain: document.getElementById('galleryMain'),
      galleryThumbs: document.getElementById('galleryThumbs'),
      productModalTitle: document.getElementById('productModalTitle'),
      productDescription: document.getElementById('productDescription'),
      productPrice: document.getElementById('productPrice'),
      productStock: document.getElementById('productStock'),
      productStatus: document.getElementById('productStatus'),
      modalAddCart: document.getElementById('modalAddCart'),
      modalWishlist: document.getElementById('modalWishlist'),
      modalCompare: document.getElementById('modalCompare'),
      relatedProducts: document.getElementById('relatedProducts'),
      productVideo: document.getElementById('productVideo'),
      cartDrawer: document.getElementById('cartDrawer'),
      cartClose: document.getElementById('cartClose'),
      cartItems: document.getElementById('cartItems'),
      cartSubtotal: document.getElementById('cartSubtotal'),
      cartShipping: document.getElementById('cartShipping'),
      cartDiscount: document.getElementById('cartDiscount'),
      cartTotal: document.getElementById('cartTotal'),
      couponInput: document.getElementById('couponInput'),
      applyCoupon: document.getElementById('applyCoupon'),
      checkoutButton: document.getElementById('checkoutButton'),
      authModal: document.getElementById('authModal'),
      authClose: document.getElementById('authClose'),
      authModalTitle: document.getElementById('authModalTitle'),
      tabs: Array.from(document.querySelectorAll('.tab')),
      tabPanels: Array.from(document.querySelectorAll('.tab-panel')),
      loginForm: document.getElementById('loginForm'),
      registerForm: document.getElementById('registerForm'),
      forgotForm: document.getElementById('forgotForm'),
      profileModal: document.getElementById('profileModal'),
      profileClose: document.getElementById('profileClose'),
      profileName: document.getElementById('profileName'),
      profileEmail: document.getElementById('profileEmail'),
      profileStatus: document.getElementById('profileStatus'),
      orderHistory: document.getElementById('orderHistory'),
      logoutButton: document.getElementById('logoutButton'),
      deleteAccountButton: document.getElementById('deleteAccountButton'),
      wishListButton: document.getElementById('wishListButton'),
      compareButton: document.getElementById('compareButton'),
      cartButton: document.getElementById('cartButton'),
      profileButton: document.getElementById('profileButton'),
      viewProductsBtn: document.getElementById('viewProductsBtn'),
      viewDealsBtn: document.getElementById('viewDealsBtn'),
      recentlyViewed: document.getElementById('recentlyViewed'),
      bundleList: document.getElementById('bundleList')
    };

    const authForms = {
      loginEmail: document.getElementById('loginEmail'),
      loginPassword: document.getElementById('loginPassword'),
      registerName: document.getElementById('registerName'),
      registerEmail: document.getElementById('registerEmail'),
      registerPassword: document.getElementById('registerPassword'),
      forgotEmail: document.getElementById('forgotEmail')
    };

    const localized = {
      USD: { locale: 'en-US', currency: 'USD' },
      EUR: { locale: 'de-DE', currency: 'EUR' },
      GBP: { locale: 'en-GB', currency: 'GBP' },
      INR: { locale: 'en-IN', currency: 'INR' },
      PKR: { locale: 'en-PK', currency: 'PKR' },
      JPY: { locale: 'ja-JP', currency: 'JPY' }
    };

    const rates = { USD: 1, EUR: 0.92, GBP: 0.80, INR: 83, PKR: 280, JPY: 149 };

    function formatPrice(value) {
      const locale = localized[currentCurrency] || localized.USD;
      const total = value * (rates[currentCurrency] || 1);
      return new Intl.NumberFormat(locale.locale, { style: 'currency', currency: locale.currency, minimumFractionDigits: currentCurrency === 'JPY' ? 0 : 2 }).format(total);
    }

    function saveState() {
      localStorage.setItem('skylineCart', JSON.stringify(cart));
      localStorage.setItem('skylineWishlist', JSON.stringify(wishlist));
      localStorage.setItem('skylineCompare', JSON.stringify(compare));
      localStorage.setItem('skylineRecentlyViewed', JSON.stringify(recentlyViewed));
      if (appliedCoupon) localStorage.setItem('skylineCoupon', appliedCoupon);
    }

    function updateCounters() {
      DOM.cartCount.textContent = cart.length;
      DOM.wishCount.textContent = wishlist.length;
      DOM.compareCount.textContent = compare.length;
      DOM.sellerProductsCount.textContent = productData.length;
    }

    function adjustBodyForHeader() {
      const header = document.querySelector('.page-header');
      if (!header) return;
      const h = header.offsetHeight;
      document.body.style.paddingTop = h + 'px';
    }

    function getFilteredProducts() {
      const searchTerm = DOM.searchInput.value.trim().toLowerCase();
      let list = productData.slice();

      if (currentCategory !== 'All') {
        list = list.filter(product => product.category === currentCategory);
      }

      if (searchTerm) {
        list = list.filter(product => [product.title, product.description, product.category, product.tags.join(' ')].some(field => field.toLowerCase().includes(searchTerm)));
      }

      if (currentSort === 'new') {
        list = list.filter(product => product.tags.includes('New arrival'));
      } else if (currentSort === 'low') {
        list.sort((a, b) => a.price - b.price);
      } else if (currentSort === 'high') {
        list.sort((a, b) => b.price - a.price);
      } else if (currentSort === 'rating') {
        list.sort((a, b) => b.rating - a.rating);
      }

      return list;
    }

    function renderProducts() {
      const products = getFilteredProducts();
      DOM.productGrid.innerHTML = products.length ? products.map(product => `
        <article class="product-card" data-id="${product.id}">
          <span class="badge-top">${product.tags[0] || ''}</span>
          <div class="product-image"><img src="${product.image}" alt="${product.title}" /></div>
          <div class="product-body">
            <h3>${product.title}</h3>
            <p>${product.description}</p>
            <div class="product-meta">
              <span class="product-price">${formatPrice(product.price)}</span>
              <span>${product.rating}★</span>
            </div>
          </div>
          <div class="product-actions">
            <button class="btn-primary" data-action="quick-view" data-id="${product.id}">Quick View</button>
            <button class="btn-outline btn-small" data-action="add-cart" data-id="${product.id}">Add to Cart</button>
            <button class="btn-outline btn-small" data-action="wishlist" data-id="${product.id}">${wishlist.includes(product.id) ? 'Saved' : 'Wishlist'}</button>
            <button class="btn-outline btn-small" data-action="compare" data-id="${product.id}">${compare.includes(product.id) ? 'Compare ✓' : 'Compare'}</button>
          </div>
        </article>
      `).join('') : '';
      DOM.noResults.classList.toggle('hidden', products.length > 0);
    }

    function renderCategories() {
      DOM.categoryList.innerHTML = categories.map(category => `
        <button type="button" class="pill ${category === currentCategory ? 'active' : ''}" data-category="${category}">${category}</button>
      `).join('');
    }

    function renderRecentlyViewed() {
      const list = recentlyViewed.slice(0, 4).map(productId => productData.find(product => product.id === productId)).filter(Boolean);
      DOM.recentlyViewed.innerHTML = list.length ? list.map(product => `
        <div class="related-card">
          <img src="${product.image}" alt="${product.title}" />
          <strong>${product.title}</strong>
          <small>${formatPrice(product.price)}</small>
          <button type="button" data-related="${product.id}">View</button>
        </div>
      `).join('') : '<p>No recently viewed products yet.</p>';
    }

    function renderBundles() {
      const bundles = productData.filter(p => p.tags.includes('Bundle')).slice(0, 3);
      DOM.bundleList.innerHTML = bundles.length ? bundles.map(product => `
        <div class="related-card">
          <strong>${product.title}</strong>
          <span>${formatPrice(product.price)}</span>
          <button type="b utton" data-related="${product.id}">View bundle</button>
        </div>
      `).join('') : '<p>No bundles available.</p>';
    }

    function openModal(modal) {
      modal.classList.remove('hidden');
      modal.setAttribute('aria-hidden', 'false');
    }

    function closeModal(modal) {
      modal.classList.add('hidden');
      modal.setAttribute('aria-hidden', 'true');
    }

    function addToCart(productId) {
      const product = productData.find(item => item.id === productId);
      if (!product) return;
      cart.push({ ...product, quantity: 1 });
      saveState();
      updateCounters();
      renderCart();
      openModal(DOM.cartDrawer);
    }

    function toggleWishlist(productId) {
      if (wishlist.includes(productId)) {
        wishlist = wishlist.filter(item => item !== productId);
      } else {
        wishlist.push(productId);
      }
      saveState();
      updateCounters();
      renderProducts();
    }

    function toggleCompare(productId) {
      if (compare.includes(productId)) {
        compare = compare.filter(item => item !== productId);
      } else {
        compare.push(productId);
      }
      saveState();
      updateCounters();
      renderProducts();
    }

    function openProduct(productId) {
      const product = productData.find(item => item.id === productId);
      if (!product) return;
      currentProduct = product;
      DOM.productModalTitle.textContent = product.title;
      DOM.productDescription.textContent = product.description;
      DOM.productPrice.textContent = formatPrice(product.price);
      DOM.productStock.textContent = `${product.stock} in stock`;
      DOM.productStatus.textContent = product.section;
      DOM.modalAddCart.dataset.id = product.id;
      DOM.modalWishlist.dataset.id = product.id;
      DOM.modalCompare.dataset.id = product.id;
      DOM.modalWishlist.textContent = wishlist.includes(product.id) ? 'Saved to wishlist' : 'Save to wishlist';
      DOM.modalCompare.textContent = compare.includes(product.id) ? 'In compare' : 'Compare';
      renderGallery(product.gallery);
      renderRelated(product.category, product.id);
      if (product.video) {
        DOM.productVideo.innerHTML = `<iframe width="100%" height="100%" src="${product.video}" title="${product.title} video" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>`;
      } else {
        DOM.productVideo.innerHTML = '<div style="display:grid;place-items:center;height:100%;color:var(--muted);">No video available</div>';
      }
      recentlyViewed = [productId, ...recentlyViewed.filter(id => id !== productId)].slice(0, 8);
      saveState();
      renderRecentlyViewed();
      openModal(DOM.productModal);
    }

    function renderGallery(images) {
      DOM.galleryMain.innerHTML = `<img src="${images[0] || ''}" alt="Product photo" />`;
      DOM.galleryThumbs.innerHTML = images.map((src, index) => `
        <div class="gallery-thumb ${index === 0 ? 'active' : ''}" data-src="${src}">
          <img src="${src}" alt="Gallery thumbnail" />
        </div>
      `).join('');
    }

    function renderRelated(category, productId) {
      const related = productData.filter(item => item.category === category && item.id !== productId).slice(0, 4);
      DOM.relatedProducts.innerHTML = related.length ? related.map(product => `
        <div class="related-card">
          <img src="${product.image}" alt="${product.title}" />
          <strong>${product.title}</strong>
          <span>${formatPrice(product.price)}</span>
          <button type="button" data-related="${product.id}">View</button>
        </div>
      `).join('') : '<p>No related products available.</p>';
    }

    function renderCart() {
      if (!cart.length) {
        DOM.cartItems.innerHTML = '<p>Your cart is empty. Add products to get started.</p>';
        DOM.cartSubtotal.textContent = formatPrice(0);
        DOM.cartShipping.textContent = formatPrice(0);
        DOM.cartDiscount.textContent = formatPrice(0);
        DOM.cartTotal.textContent = formatPrice(0);
        return;
      }
      let subtotal = 0;
      DOM.cartItems.innerHTML = cart.map((item, index) => {
        const itemTotal = item.price * item.quantity;
        subtotal += itemTotal;
        return `
          <div class="account-card" style="grid-template-columns: 1fr auto; align-items:center; gap:12px;">
            <div>
              <strong>${item.title}</strong>
              <div>${formatPrice(item.price)} × ${item.quantity} = ${formatPrice(itemTotal)}</div>
            </div>
            <div style="display:grid; gap:8px; text-align:right;">
              <button class="link-button" data-change="${index}" data-delta="-1">−</button>
              <button class="link-button" data-change="${index}" data-delta="1">+</button>
              <button class="link-button" data-remove="${index}">Remove</button>
            </div>
          </div>
        `;
      }).join('');
      const shipping = subtotal ? 5 : 0;
      const discount = appliedCoupon ? (coupons[appliedCoupon] < 1 ? subtotal * coupons[appliedCoupon] : coupons[appliedCoupon]) : 0;
      const total = Math.max(0, subtotal + shipping - discount);
      DOM.cartSubtotal.textContent = formatPrice(subtotal);
      DOM.cartShipping.textContent = formatPrice(shipping);
      DOM.cartDiscount.textContent = formatPrice(discount);
      DOM.cartTotal.textContent = formatPrice(total);
      saveState();
    }

    function renderProfile() {
      if (!currentUser) {
        document.getElementById('profileName').textContent = 'Guest Shopper';
        document.getElementById('profileEmail').textContent = 'Not signed in';
        document.getElementById('profileStatus').textContent = 'Register or login to save your data.';
        DOM.orderHistory.innerHTML = '<tr><td colspan="4">No orders yet.</td></tr>';
        return;
      }
      document.getElementById('profileName').textContent = currentUser.name;
      document.getElementById('profileEmail').textContent = currentUser.email;
      document.getElementById('profileStatus').textContent = 'Member account active. Manage orders, addresses, and payment methods.';
      const orders = currentUser.orders || [];
      DOM.orderHistory.innerHTML = orders.length ? orders.map(order => `
        <tr>
          <td>${order.id}</td>
          <td>${order.status}</td>
          <td>${formatPrice(order.total)}</td>
          <td><button class="link-button" data-invoice="${order.id}">Invoice</button></td>
        </tr>
      `).join('') : '<tr><td colspan="4">No orders yet.</td></tr>';
    }

    function showProfilePanel() {
      if (!currentUser) {
        openModal(DOM.authModal);
        return;
      }
      renderProfile();
      openModal(DOM.profileModal);
    }

    function handleAuthTabClick(event) {
      const tab = event.target.closest('.tab');
      if (!tab) return;
      const target = tab.dataset.tab;
      DOM.tabs.forEach(button => button.classList.toggle('active', button === tab));
      DOM.tabPanels.forEach(panel => panel.classList.toggle('active', panel.id === `tab-${target}`));
      DOM.authModalTitle.textContent = target === 'login' ? 'Login' : target === 'register' ? 'Register' : 'Reset password';
    }

    function openAuth() {
      openModal(DOM.authModal);
    }

    function setInitialCurrency() {
      const locale = navigator.language.toLowerCase();
      if (locale.startsWith('en-gb')) return 'GBP';
      if (locale.startsWith('en-in')) return 'INR';
      if (locale.startsWith('ur')) return 'PKR';
      if (locale.startsWith('ja')) return 'JPY';
      if (locale.startsWith('de') || locale.startsWith('fr') || locale.startsWith('es')) return 'EUR';
      return 'USD';
    }

    function init() {
      currentCurrency = setInitialCurrency();
      DOM.currencySelector.value = currentCurrency;
      updateCounters();
      renderCategories();
      renderProducts();
      renderRecentlyViewed();
      renderBundles();
      renderCart();
      renderProfile();
    }

    DOM.searchForm.addEventListener('submit', event => {
      event.preventDefault();
      renderProducts();
    });

    DOM.categoryList.addEventListener('click', event => {
      const button = event.target.closest('[data-category]');
      if (!button) return;
      currentCategory = button.dataset.category;
      renderCategories();
      renderProducts();
    });

    DOM.sortSelect.addEventListener('change', event => {
      currentSort = event.target.value;
      renderProducts();
    });

    DOM.currencySelector.addEventListener('change', event => {
      currentCurrency = event.target.value;
      renderProducts();
      renderCart();
      renderRecentlyViewed();
      renderBundles();
    });

    document.body.addEventListener('click', event => {
      const addCart = event.target.closest('[data-action="add-cart"]');
      const wishlistBtn = event.target.closest('[data-action="wishlist"]');
      const compareBtn = event.target.closest('[data-action="compare"]');
      const quickView = event.target.closest('[data-action="quick-view"]');
      const related = event.target.closest('[data-related]');
      const remove = event.target.closest('[data-remove]');
      const change = event.target.closest('[data-change]');
      const invoice = event.target.closest('[data-invoice]');
      const productThumb = event.target.closest('.gallery-thumb');

      if (addCart) {
        addToCart(addCart.dataset.id);
      }
      if (wishlistBtn) {
        toggleWishlist(wishlistBtn.dataset.id);
      }
      if (compareBtn) {
        toggleCompare(compareBtn.dataset.id);
      }
      if (quickView) {
        openProduct(quickView.dataset.id);
      }
      if (related) {
        openProduct(related.dataset.related);
      }
      if (remove && remove.dataset.remove !== undefined) {
        const index = Number(remove.dataset.remove);
        cart.splice(index, 1);
        renderCart();
        updateCounters();
      }
      if (change && change.dataset.change !== undefined) {
        const index = Number(change.dataset.change);
        const delta = Number(change.dataset.delta);
        if (!cart[index]) return;
        cart[index].quantity = Math.max(1, cart[index].quantity + delta);
        renderCart();
      }
      if (invoice) {
        alert('Invoice download for ' + invoice.dataset.invoice + ' is not available in demo mode.');
      }
      if (productThumb) {
        const src = productThumb.dataset.src;
        DOM.galleryMain.querySelector('img').src = src;
        document.querySelectorAll('.gallery-thumb').forEach(thumb => thumb.classList.toggle('active', thumb === productThumb));
      }
    });

    DOM.modalAddCart.addEventListener('click', () => {
      if (!currentProduct) return;
      addToCart(currentProduct.id);
    });

    DOM.modalWishlist.addEventListener('click', () => {
      if (!currentProduct) return;
      toggleWishlist(currentProduct.id);
      DOM.modalWishlist.textContent = wishlist.includes(currentProduct.id) ? 'Saved to wishlist' : 'Save to wishlist';
    });

    DOM.modalCompare.addEventListener('click', () => {
      if (!currentProduct) return;
      toggleCompare(currentProduct.id);
      DOM.modalCompare.textContent = compare.includes(currentProduct.id) ? 'In compare' : 'Compare';
    });

    DOM.cartButton.addEventListener('click', () => openModal(DOM.cartDrawer));
    DOM.cartClose.addEventListener('click', () => closeModal(DOM.cartDrawer));
    DOM.authClose.addEventListener('click', () => closeModal(DOM.authModal));
    DOM.profileClose.addEventListener('click', () => closeModal(DOM.profileModal));
    DOM.wishListButton.addEventListener('click', () => alert('Wishlist panel is available in future updates.')); 
    DOM.compareButton.addEventListener('click', () => alert('Compare panel is available in future updates.'));
    DOM.profileButton.addEventListener('click', showProfilePanel);
    DOM.viewProductsBtn.addEventListener('click', () => window.scrollTo({ top: document.querySelector('.page-body').offsetTop - 20, behavior: 'smooth' }));
    DOM.viewDealsBtn.addEventListener('click', () => {
      currentSort = 'rating';
      DOM.sortSelect.value = 'rating';
      renderProducts();
      window.scrollTo({ top: document.querySelector('.page-body').offsetTop - 20, behavior: 'smooth' });
    });

    DOM.applyCoupon.addEventListener('click', () => {
      const code = DOM.couponInput.value.trim().toUpperCase();
      if (!code || !coupons[code]) {
        alert('Invalid coupon code. Try STACK10, SAVE15, or GIFT50.');
        return;
      }
      appliedCoupon = code;
      saveState();
      renderCart();
      alert(`Coupon ${code} applied!`);
    });

    DOM.checkoutButton.addEventListener('click', () => {
      if (!cart.length) {
        alert('Please add products to your cart before checking out.');
        return;
      }
      if (!currentUser) {
        openAuth();
        return;
      }
      alert('Checkout complete! Thank you for shopping with Skyline Shop.');
      cart = [];
      appliedCoupon = '';
      DOM.couponInput.value = '';
      saveState();
      renderCart();
      closeModal(DOM.cartDrawer);
    });

    DOM.tabs.forEach(tab => tab.addEventListener('click', handleAuthTabClick));

    DOM.loginForm.addEventListener('submit', event => {
      event.preventDefault();
      const email = authForms.loginEmail.value.trim();
      const password = authForms.loginPassword.value.trim();
      if (!email || !password) return;
      currentUser = { name: email.split('@')[0], email, orders: [{ id: 'ORD-1001', status: 'Delivered', total: 199 }, { id: 'ORD-1002', status: 'Processing', total: 79 }] };
      localStorage.setItem('skylineUser', JSON.stringify(currentUser));
      renderProfile();
      closeModal(DOM.authModal);
      alert('Logged in successfully.');
    });

    DOM.registerForm.addEventListener('submit', event => {
      event.preventDefault();
      const name = authForms.registerName.value.trim();
      const email = authForms.registerEmail.value.trim();
      const password = authForms.registerPassword.value.trim();
      if (!name || !email || !password) return;
      currentUser = { name, email, orders: [] };
      localStorage.setItem('skylineUser', JSON.stringify(currentUser));
      renderProfile();
      closeModal(DOM.authModal);
      alert('Account created successfully.');
    });

    DOM.forgotForm.addEventListener('submit', event => {
      event.preventDefault();
      const email = authForms.forgotEmail.value.trim();
      if (!email) return;
      alert(`A password reset link was sent to ${email}.`);
      authForms.forgotEmail.value = '';
    });

    DOM.logoutButton.addEventListener('click', () => {
      currentUser = null;
      localStorage.removeItem('skylineUser');
      renderProfile();
      alert('You have been logged out.');
    });

    DOM.deleteAccountButton.addEventListener('click', () => {
      if (!confirm('Delete your demo account and all saved preferences?')) return;
      currentUser = null;
      localStorage.removeItem('skylineUser');
      renderProfile();
      alert('Account deleted.');
    });

    [DOM.productModal, DOM.cartDrawer, DOM.authModal, DOM.profileModal].forEach(modal => {
      modal.addEventListener('click', event => {
        if (event.target === modal) closeModal(modal);
      });
    });

    init();
    adjustBodyForHeader();
    window.addEventListener('resize', adjustBodyForHeader);
  </script>
</body>
</html>
